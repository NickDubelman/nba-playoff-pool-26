---
import { Image } from 'astro:assets'
import malatesta from '../images/malatesta.png'
import david from '../images/david.png'
import daniel from '../images/daniel.png'
---

<h2 class="text-2xl font-bold py-3">Last Year's Podium</h2>

<h3 class="text-xl font-bold py-2">1st Place 🥇</h3>
<Image src={malatesta} alt="malatesta" width={420} />

<h3 class="text-xl font-bold py-2">2nd Place 🥈</h3>
<Image src={david} alt="david" width={420} />

<h3 class="text-xl font-bold py-2">3rd Place 🥉</h3>
<Image src={daniel} alt="daniel" width={420} />
